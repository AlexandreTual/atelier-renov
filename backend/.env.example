# Copier ce fichier en .env et remplir les valeurs
# Ne jamais commiter .env dans le dépôt git.

# ---- Auth (OBLIGATOIRES — le serveur refuse de démarrer sans elles) --------
JWT_SECRET=change-me-with-a-long-random-string-min-32-chars
ADMIN_PASSWORD=change-me-min-8-chars

# ---- Serveur ----------------------------------------------------------------
PORT=5000
NODE_ENV=development

# ---- Mode de fonctionnement ------------------------------------------------
# true = SQLite local + images sur disque
# false (ou absent) = PostgreSQL + Cloudinary
USE_LOCAL_MODE=true

# ---- Base de données -------------------------------------------------------
# PostgreSQL (cloud uniquement, ignoré si USE_LOCAL_MODE=true)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# SQLite (local uniquement, chemin relatif au dossier backend/)
SQLITE_PATH=./database.sqlite

# ---- Stockage images (cloud uniquement) ------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- CORS ------------------------------------------------------------------
# URL exacte du frontend sans slash final (utilisée par getAllowedOrigins())
# En développement : http://localhost:5173
# En production : https://votre-app.vercel.app
FRONTEND_URL=http://localhost:5173

# ---- Logging (pino) --------------------------------------------------------
# Niveaux disponibles : trace, debug, info, warn, error, fatal
LOG_LEVEL=info
