# Copier ce fichier en .env et remplir les valeurs
# Ne jamais commiter .env

# Auth — valeurs obligatoires au démarrage (le serveur refuse de démarrer sans elles)
JWT_SECRET=change-me-with-a-long-random-string
ADMIN_PASSWORD=change-me

# Serveur
PORT=5000

# Base de données
# true = SQLite local, false/absent = PostgreSQL
USE_LOCAL_MODE=true
DATABASE_URL=postgres://user:password@host:5432/dbname

# Cloudinary (optionnel en local, requis en production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS — origines autorisées (séparées par virgule)
ALLOWED_ORIGINS=http://localhost:5173
